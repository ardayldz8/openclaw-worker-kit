{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "jobs.yaml schema v2",
  "type": "object",
  "required": ["version", "jobs"],
  "properties": {
    "version": {"type": "string", "const": "v2"},
    "jobs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["command"],
        "properties": {
          "description": {"type": "string"},
          "command": {"type": "string"},
          "timeout_sec": {"type": "integer", "minimum": 1},
          "retries": {"type": "integer", "minimum": 1},
          "env": {"type": "object", "additionalProperties": {"type": ["string","number","boolean"]}},
          "owner": {"type": "string"},
          "tags": {"type": "array", "items": {"type": "string"}},
          "sla_sec": {"type": "integer", "minimum": 1},
          "resume_strategy": {"type": "string", "enum": ["strict","best-effort"]},
          "alert_policy": {
            "type": "object",
            "properties": {
              "enabled": {"type": "boolean"},
              "fail_threshold": {"type": "integer", "minimum": 1},
              "cooldown_sec": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "chains": {"type": "object"}
  },
  "additionalProperties": false
}
